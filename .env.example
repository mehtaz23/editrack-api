# DATABASE_URL — overrides appsettings.Development.json connection string in CI and production.
# Set to a full PostgreSQL connection string, e.g.:
# DATABASE_URL=Host=myhost;Port=5432;Database=editrack;Username=editrack;Password=secret
DATABASE_URL=

# ALLOWED_CORS_ORIGINS — comma-separated list of allowed CORS origins.
# Default targets the spec-lab UI local dev origin.
# Override with a comma-separated list or a single production origin in deployed environments.
ALLOWED_CORS_ORIGINS=http://localhost:3000
